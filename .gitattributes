# Package source and build metadata must have checkout-stable bytes so a fixed
# SOURCE_DATE_EPOCH can produce the same wheel from a fresh Windows clone.
.gitattributes text eol=lf
*.py text eol=lf
*.mjs text eol=lf
pyproject.toml text eol=lf
LICENSE text eol=lf

# Target-decision evidence has an explicit cross-platform serialization contract.
samples/target/phase-two/*.json text eol=lf
samples/target/phase-two/*.html text eol=lf

# Optical-pair evidence has an explicit cross-platform serialization contract.
samples/optical/phase-two/*.json text eol=lf
samples/optical/phase-two/*.html text eol=lf

# Content-registration evidence has an explicit cross-platform serialization contract.
samples/registration/phase-two/*.json text eol=lf
samples/registration/phase-two/*.html text eol=lf

# Label-proposal and QA evidence have explicit cross-platform serialization contracts.
samples/labels/phase-two/*.json text eol=lf
samples/labels/phase-two/*.html text eol=lf

# Cross-event label-transfer and QA evidence use the same LF contract.
samples/labels/cross-event/phase-two/*.json text eol=lf
samples/labels/cross-event/phase-two/*.html text eol=lf

# Label-review packet and integrity QA evidence use the same LF contract.
samples/labels/review/phase-two/*.json text eol=lf
samples/labels/review/phase-two/*.html text eol=lf
samples/labels/review/phase-two/*.txt text eol=lf

# Prototype-label readiness evidence has an exact cross-platform byte contract.
samples/labels/readiness/phase-two/*.json text eol=lf
samples/labels/readiness/phase-two/*.html text eol=lf
samples/labels/pilot/phase-two/*.json text eol=lf
samples/labels/pilot/phase-two/*.html text eol=lf
samples/labels/review/regions/phase-two/*.json text eol=lf
samples/labels/review/regions/phase-two/*.html text eol=lf
samples/labels/review/regions/phase-two/intake/*.json text eol=lf
samples/labels/review/regions/phase-two/intake/*.html text eol=lf

# Cross-event source and feasibility evidence have explicit cross-platform serialization contracts.
samples/cross-event/phase-two/*.json text eol=lf
samples/cross-event/phase-two/*.html text eol=lf

# Current cross-program reference inventory evidence has the same LF contract.
samples/reference/phase-two/*.json text eol=lf
samples/reference/phase-two/*.html text eol=lf
